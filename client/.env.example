# Copiar a .env.local (Create React App lo carga en desarrollo)
REACT_APP_API_URL=http://localhost:3001
# Acceso desde móvil en la misma WiFi (ver también HOST en .env.local):
# HOST=0.0.0.0
# DANGEROUSLY_DISABLE_HOST_CHECK=true
# WDS_SOCKET_PORT=0
# REACT_APP_API_URL=http://TU_IP_LAN:3001
# Nombre de la organización (aparece en cabecera de reportes exportados, CSV/Excel AEPG)
# REACT_APP_EMPRESA_NOMBRE=Mi empresa

# Opcional: menos avisos en la terminal al compilar (ver .env.local)
# DISABLE_ESLINT_PLUGIN=true
# GENERATE_SOURCEMAP=false
