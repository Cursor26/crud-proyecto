# ===== App =====
APP_BASE_URL=http://localhost:3000
PASSWORD_RESET_TTL_MINUTES=30
JWT_SECRET=pon_aqui_un_secreto_largo_y_aleatorio

# ===== SMTP real =====
# Ejemplo Gmail: host=smtp.gmail.com, port=587, secure=false
SMTP_REQUIRED=true
SMTP_HOST=smtp.tudominio.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=notificaciones@tudominio.com
SMTP_PASS=tu_password_o_app_password
SMTP_FROM="Pecuaria Genetica <notificaciones@tudominio.com>"
# SMTP alternativo opcional (segundo servidor/proveedor)
SMTP_ALT_HOST=
SMTP_ALT_PORT=587
SMTP_ALT_SECURE=false
SMTP_ALT_USER=
SMTP_ALT_PASS=
# Si SMTP falla por red:
# - graceful: responde 200 con warning y enlace temporal de reset
# - strict: responde error 5xx
MAIL_FALLBACK_MODE=graceful
RESET_LINK_FALLBACK_ENABLED=true
# Timeouts SMTP (ms) para redes inestables / VPN
SMTP_CONNECTION_TIMEOUT=15000
SMTP_GREETING_TIMEOUT=12000
SMTP_SOCKET_TIMEOUT=20000
