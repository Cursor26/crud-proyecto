digraph MODELO_BD_CRUD {
  graph [
    rankdir=LR
    splines=ortho
    nodesep=0.35
    ranksep=1.4
    bgcolor="#FAFAFA"
    pad=0.6
    fontsize=11
    fontname="Segoe UI"
    label="Modelo Entidad-Relación — bd_crud (normalizado 3FN)\nTodas las tablas, atributos y relaciones"
    labelloc=t
    fontsize=16
  ];
  node [fontname="Segoe UI"];
  edge [arrowsize=0.7];

  subgraph cluster_usuarios {
    label="Usuarios y seguridad";
    style=filled;
    color="#E8EEF7";
    fontsize=14;
    fontname="Segoe UI";
    password_reset_tokens [label=<
